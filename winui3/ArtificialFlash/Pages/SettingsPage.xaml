<Page
    x:Class="ArtificialFlash.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="16" MaxWidth="600">
            <TextBlock Text="Settings" 
                       Style="{StaticResource TitleTextBlockStyle}"
                       FontSize="24" FontWeight="Bold"/>

            <StackPanel Background="{ThemeResource CardBackground}"
                        CornerRadius="12" Padding="16" Spacing="12">
                <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold"/>

                <ToggleSwitch x:Name="DarkModeToggle" Header="Dark Mode"
                              Toggled="OnDarkModeToggle"/>

                <ComboBox x:Name="LanguageCombo" Header="Language"
                          SelectedIndex="0">
                    <ComboBoxItem Content="English"/>
                    <ComboBoxItem Content="Chinese (&#x4E2D;&#x6587;)"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Background="{ThemeResource CardBackground}"
                        CornerRadius="12" Padding="16" Spacing="12">
                <TextBlock Text="Server Connection" FontSize="18" FontWeight="SemiBold"/>

                <ToggleSwitch x:Name="RemoteToggle" Header="Remote Server Mode"
                              Toggled="OnRemoteToggle"/>

                <TextBox x:Name="HostBox" Header="Host"
                         PlaceholderText="localhost"/>
                <NumberBox x:Name="PortBox" Header="Port"
                           Value="8000" Minimum="1" Maximum="65535"/>

                <Button x:Name="TestConnectionBtn" 
                        Click="OnTestConnection">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A7;"/>
                        <TextBlock Text="Test Connection"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Background="{ThemeResource CardBackground}"
                        CornerRadius="12" Padding="16" Spacing="8">
                <TextBlock Text="About" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="ArtificialFlash 能工智人 v1.0.0"/>
                <TextBlock Text="AI Training Assistant for Windows"
                           Opacity="0.7"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

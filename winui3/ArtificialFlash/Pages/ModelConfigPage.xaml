<Page
    x:Class="ArtificialFlash.ModelConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="16" MaxWidth="600">
            <TextBlock Text="Create New Model" 
                       Style="{StaticResource TitleTextBlockStyle}"
                       FontSize="24" FontWeight="Bold"/>

            <TextBox x:Name="ModelNameBox" Header="Model Name"
                     PlaceholderText="Enter model name"/>

            <ComboBox x:Name="CategoryCombo" Header="Category"
                      SelectedIndex="0">
                <ComboBoxItem Content="Visual"/>
                <ComboBoxItem Content="NLP"/>
                <ComboBoxItem Content="Generative"/>
                <ComboBoxItem Content="Custom"/>
            </ComboBox>

            <ComboBox x:Name="ArchitectureCombo" Header="Architecture">
                <ComboBoxItem Content="Image Classification"/>
                <ComboBoxItem Content="Object Detection"/>
                <ComboBoxItem Content="Text Classification"/>
                <ComboBoxItem Content="Sentiment Analysis"/>
            </ComboBox>

            <TextBlock Text="Training Parameters"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       FontSize="18" FontWeight="SemiBold"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <NumberBox x:Name="LearningRateBox" Grid.Row="0" Grid.Column="0"
                           Header="Learning Rate" Value="0.001" 
                           SmallChange="0.001" LargeChange="0.01"
                           NumberFormatter="{}{0:0.000}" Margin="0,0,8,0"/>

                <NumberBox x:Name="EpochsBox" Grid.Row="0" Grid.Column="1"
                           Header="Epochs" Value="10"
                           SmallChange="1" LargeChange="10" Margin="8,0,0,0"/>

                <NumberBox x:Name="BatchSizeBox" Grid.Row="1" Grid.Column="0"
                           Header="Batch Size" Value="16"
                           SmallChange="1" LargeChange="8" Margin="0,0,8,0"/>

                <NumberBox x:Name="ImageSizeBox" Grid.Row="1" Grid.Column="1"
                           Header="Image Size" Value="28"
                           SmallChange="1" LargeChange="8" Margin="8,0,0,0"/>
            </Grid>

            <ToggleSwitch x:Name="DataAugToggle"
                          Header="Data Augmentation"
                          IsOn="False"/>

            <Button x:Name="CreateModelBtn" 
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch" Height="44"
                    Click="OnCreateModel">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE943;"/>
                    <TextBlock Text="Create Model" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Page>

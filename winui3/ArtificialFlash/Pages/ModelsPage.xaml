<Page
    x:Class="ArtificialFlash.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Models" 
                   Style="{StaticResource TitleTextBlockStyle}"
                   FontSize="24" FontWeight="Bold"
                   Padding="32,16,32,0"/>

        <GridView x:Name="ModelsGrid" Grid.Row="1"
                  Padding="32,16" SelectionMode="Single"
                  ItemClick="OnModelClick">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="280" Padding="16"
                          Background="{ThemeResource CardBackground}"
                          CornerRadius="12">
                        <StackPanel Spacing="8">
                            <FontIcon Glyph="&#xE943;" FontSize="32"
                                      Foreground="{StaticResource AppAccentColor}"/>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Type}" Opacity="0.7"/>
                            <TextBlock x:Name="StatusBlock" 
                                       Text="{Binding Status}"/>
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Text="Acc:" FontSize="12"/>
                                    <TextBlock Text="{Binding Accuracy}" FontSize="12"/>
                                    <TextBlock Text="Loss:" FontSize="12"/>
                                    <TextBlock Text="{Binding Loss}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <CommandBar Grid.Row="2">
            <AppBarButton Icon="Add" Label="New Model" Click="OnNewModel"/>
        </CommandBar>
    </Grid>
</Page>

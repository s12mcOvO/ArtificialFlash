<Page
    x:Class="ArtificialFlash.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="32">
            <TextBlock Text="Welcome to ArtificialFlash" 
                       Style="{StaticResource TitleTextBlockStyle}"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource AppAccentColor}"/>

            <TextBlock Text="Your AI Training Assistant"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Opacity="0.8"/>

            <GridView x:Name="StatsGrid">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.DatasetCount, Mode=OneWay}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource AppAccentColor}"/>
                        <TextBlock Text="Datasets" Opacity="0.7"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.ModelCount, Mode=OneWay}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource AppAccentColor}"/>
                        <TextBlock Text="Models" Opacity="0.7"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.BackendStatus, Mode=OneWay}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Backend Status" Opacity="0.7"/>
                    </StackPanel>
                </Grid>
            </GridView>

            <TextBlock Text="Quick Actions" 
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       FontSize="20" FontWeight="SemiBold"/>

            <GridView x:Name="QuickActionsGrid">
                <Button x:Name="NewDatasetBtn" Style="{StaticResource AccentButtonStyle}"
                        Click="OnNewDataset">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;"/>
                        <TextBlock Text="Upload Data"/>
                    </StackPanel>
                </Button>
                <Button x:Name="NewModelBtn" Style="{StaticResource AccentButtonStyle}"
                        Click="OnNewModel">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE943;"/>
                        <TextBlock Text="Create Model"/>
                    </StackPanel>
                </Button>
                <Button x:Name="StartTrainingBtn" Style="{StaticResource AccentButtonStyle}"
                        Click="OnStartTraining">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE768;"/>
                        <TextBlock Text="Start Training"/>
                    </StackPanel>
                </Button>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>

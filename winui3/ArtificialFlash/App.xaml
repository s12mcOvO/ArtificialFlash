<Application
    x:Class="ArtificialFlash.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AppAccentColor" Color="#6750A4"/>
            <SolidColorBrush x:Key="AppAccentLight" Color="#7C6DB0"/>
            <SolidColorBrush x:Key="AppBackground" Color="#FFFBFE"/>
            <SolidColorBrush x:Key="AppDarkBackground" Color="#1C1B1F"/>
            <SolidColorBrush x:Key="CardBackground" Color="#FFEDE7F6"/>
            <SolidColorBrush x:Key="SuccessColor" Color="#FF4CAF50"/>
            <SolidColorBrush x:Key="ErrorColor" Color="#FFE53935"/>
            <SolidColorBrush x:Key="WarningColor" Color="#FFFF9800"/>
            <SolidColorBrush x:Key="NeutralColor" Color="#FF9E9E9E"/>
            <x:Double x:Key="NavigationViewCompactModeThreshold">640</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<Window
    x:Class="ArtificialFlash.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ArtificialFlash 能工智人">

    <Grid>
        <NavigationView x:Name="AppNavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Auto"
            SelectionChanged="OnNavigationChanged"
            Loaded="OnNavLoaded">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavHome" Tag="home" Icon="Home" Content="Home"/>
                <NavigationViewItem x:Name="NavData" Tag="data" Icon="Folder" Content="Data"/>
                <NavigationViewItem x:Name="NavModels" Tag="models" Icon="Library" Content="Models"/>
                <NavigationViewItem x:Name="NavTraining" Tag="training" Icon="Play" Content="Training"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavSettings" Tag="settings" Icon="Setting" Content="Settings"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
